# Copy this file to `.env` and fill in your own values.
# NEVER commit the real .env file.

# === Alpaca PAPER trading credentials ===
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Market: "crypto" or "stock" ===
MARKET=crypto

# === Universe (comma separated) ===
# Crypto symbols must use slash, e.g. BTC/USD
CRYPTO_UNIVERSE=BTC/USD,ETH/USD,SOL/USD
STOCK_UNIVERSE=AAPL,MSFT,NVDA,GOOGL,TSLA,AMZN,META,SPY

# === Decision loop ===
DECISION_INTERVAL_MIN=30
LOOKBACK_BARS=200
BAR_TIMEFRAME=15Min

# === Risk management ===
MAX_POSITION_PCT=0.25
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06
MAX_GROSS_EXPOSURE_PCT=0.9

# === Optional LLM layer ===
# Leave empty to run pure-rules mode (baseline B3).
# Set to one of: "openai", "anthropic", "groq" to enable the LLM veto layer.
LLM_PROVIDER=

# --- OpenAI (paid) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (paid) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Groq (FREE tier, OpenAI-compatible) ---
# Get a free key at https://console.groq.com/keys
# No credit card required at the time of writing.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# end of file
